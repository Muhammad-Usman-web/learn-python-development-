num1=int(input("enter your first number = "))
num2=int(input("enter your second number = "))
op=input("enter your operation - + * % ")
if op == "+":
    ans = num1 + num2
elif op == "-":
    ans = num1 - num2
elif op == "*":
    ans = num1 * num2
elif op == "%":
    ans = num1 % num2
else:
    print ("invalid operator")
print (ans)